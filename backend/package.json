{
  "name": "matable-backend",
  "version": "1.0.0",
  "description": "MaTable backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "postbuild": "node scripts/bundle-prod.mjs",
    "build:vercel": "node scripts/bundle-vercel.mjs",
    "vercel-build": "npm run build:vercel",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "seed:demo-360": "tsx src/scripts/seed-demo-360.ts",
    "seed:fresh-catalog": "tsx src/scripts/seed-fresh-catalog.ts",
    "seed:menus": "tsx src/scripts/seed-default-menus.ts",
    "migrate:sortie-types": "tsx src/scripts/migrate-sortie-types.ts",
    "fix-klapty-urls": "tsx src/scripts/fix-klapty-urls.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
