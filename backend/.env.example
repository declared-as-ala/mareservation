# ── Database & auth (see your real .env or main project docs)
# MONGODB_URI=
# JWT_SECRET=
# REFRESH_SECRET=

# ── Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ── SOS Conseil assistant (OpenRouter) — NEVER expose OPENROUTER_API_KEY to the browser
OPENROUTER_API_KEY=replace_with_real_key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=MaTable SOS Conseil

# Optional: override default SOS chat rate window (pairs with express-rate-limit in code)
# SOS_CHAT_RATE_MAX=24

# SOS Conseil: notification email(s) on new form submit (comma or semicolon). Defaults to alamissaoui + Wassim if unset.
# SOS_CONSEIL_NOTIFICATION_EMAILS=alamissaoui.dev@gmail.com,Wassim.ouelhazi100119862@gmail.com

# Partenaire: notification email(s) on new partner application (comma or semicolon).
# Falls back to SOS_CONSEIL_NOTIFICATION_EMAILS, then the built-in default, if unset.
# PARTNER_NOTIFICATION_EMAILS=alamissaoui.dev@gmail.com,Wassim.ouelhazi100119862@gmail.com
