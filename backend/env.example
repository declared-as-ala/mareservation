# Copy this file to .env and fill in your values. Do NOT commit .env or hardcode credentials.

# MongoDB Atlas (required — no Docker Mongo). MONGODB_URI is preferred; MONGO_URI used as fallback.
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@cluster0.xxxxx.mongodb.net/mareservation?retryWrites=true&w=majority&appName=Cluster0
# MONGO_URI=... (optional fallback)

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production

# Frontend URL (for CORS and cookies)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
