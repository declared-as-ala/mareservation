# Copy this file to .env and fill in your values. Do NOT commit .env or hardcode credentials.

# MongoDB Atlas (required — no Docker Mongo). MONGODB_URI is preferred; MONGO_URI used as fallback.
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@cluster0.xxxxx.mongodb.net/mareservation?retryWrites=true&w=majority&appName=Cluster0
# MONGO_URI=... (optional fallback)

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
# Access token lifetime (jwt duration string: 15m, 2h, 7d, or bare seconds).
# Long-lived by default because the token is sent as a Bearer header which
# survives cross-port HTTP deployments where cookies are fragile.
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY_DAYS=30
# Refresh-cookie security. Keep false on plain HTTP (a `secure` cookie is
# silently dropped over HTTP); set to true once you serve the API over HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Frontend URL (for CORS and cookies)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
