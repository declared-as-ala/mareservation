# ============================================================
# Ma Reservation — Deployment Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your deployment

# ============================================================
# Frontend (Next.js) — exposed to browser
# ============================================================
# ⚠️  Set this to your VPS public IP and backend port — NO /api/v1 suffix! The client appends it.
# The frontend backend URL is hardcoded in frontend/next.config.ts.

# ============================================================
# Backend (Express) — server-side only
# ============================================================
NODE_ENV=production
PORT=5000

# MongoDB connection
# For Docker: mongodb://admin:changeme@mongodb:27017/mareservation?authSource=admin
# For local: mongodb://localhost:27017/mareservation
MONGO_URI=mongodb://admin:changeme@mongodb:27017/mareservation?authSource=admin

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# Authentication — generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-at-least-32-chars

# Token expiry
ACCESS_TOKEN_EXPIRY=15m

# ============================================================
# Email Service (Resend or SMTP)
# ============================================================
# Using Resend (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Alternative: SMTP server
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=noreply@mareservation.tn

# ============================================================
# Payment Gateway (Konnect Tunisia)
# ============================================================
KONNECT_API_URL=https://api.konnect.tn
KONNECT_API_KEY=your-konnect-api-key
KONNECT_SECRET_KEY=your-konnect-secret-key
KONNECT_ENTITY_ID=your-konnect-entity-id

# ============================================================
# File Upload Configuration
# ============================================================
UPLOAD_MAX_FILE_SIZE_MB=50

# Cloudinary (for image storage — optional, defaults to disk)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# S3 / AWS (alternative storage — optional)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ============================================================
# Optional: SOS Conseil Chat
# ============================================================
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=openai/gpt-4-turbo
# SOS_CONSEIL_NOTIFICATION_EMAILS=admin@mareservation.tn

# ============================================================
# Optional: WhatsApp Notifications (Twilio)
# ============================================================
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+216XXXXXXXX
